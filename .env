# ============================================================
# BTC Bot v13 — Configuration Overrides
# ============================================================
# These override config.py defaults.
# ============================================================

# --- TRADING MODE ---
# true  = Paper trading (simulate trades, NO real orders on Delta)
# false = Real trading (requires valid DELTA_API_KEY + DELTA_API_SECRET)
PAPER_TRADING=true

# --- CRITICAL: Enable Take Profit (trades close at target) ---
TP_HARD_EXIT=true

# --- Disable range regime (trend-only for 64% win rate) ---
ADX_RANGE_TH=5

# --- Trend-only params ---
TREND_RR=2.5
TREND_ATR_MULT=0.6
BE_MULT=0.5

# --- Delta Exchange India (REAL TRADING requires valid keys) ---
DELTA_API_KEY=YOUR_API_KEY
DELTA_API_SECRET=YOUR_API_SECRET
DELTA_TESTNET=true
SYMBOL=BTC/USD:USD
POSITION_BTC_SIZE=0.01
ALERT_QTY=1

# --- Trailing disabled (TP mode active) ---
# To re-enable Pine-exact trailing, remove these lines
