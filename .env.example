# Copy this file to .env and fill in real values. .env is git-ignored.
# The dashboard (ecosystem.config.js / dashboard/main.py) and the bot (config.py)
# read these at runtime.

# ── Turso (client dashboard DB) ──────────────────────────────
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=your-turso-auth-token

# ── Client dashboard login ───────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-strong-password

# ── Delta Exchange (bot trading) ─────────────────────────────
DELTA_API_KEY=YOUR_API_KEY
DELTA_API_SECRET=YOUR_API_SECRET
DELTA_TESTNET=true
PAPER_TRADING=true

# ── Telegram notifications (optional) ────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Live dashboard push (server.js) ──────────────────────────
DASHBOARD_PUSH_URL=http://localhost:3005/api/state
DASHBOARD_PUSH_ENABLED=true
