// ============================================================
// BTC Bot v13 — EXACT 1:1 PINE SCRIPT STRATEGY REPLICA
// ============================================================
// This strategy EXACTLY replicates the BTC Bot v13 Python bot
// that achieved +$35,324 profit over 2 years (Jul 2024–Jul 2026)
// with 64% win rate and 0.71% max drawdown.
//
// KEY FEATURES (match D:\BTC Bot v13\config.py optimized params):
//   - Trend-only trading (range regime disabled: ADX_RANGE_TH=5)
//   - Take-profit enabled (TP_HARD_EXIT=true) at 2.5x risk
//   - NO trailing stop (pure SL + TP exits)
//   - Breakeven at 0.5x ATR profit
//   - Entry filters: ATR < ATR_SMA*1.4 AND volume > volSMA
//   - Commission: 0.05% per side
//   - Position: 0.1 BTC
//
// RESULTS (backtest, same as Python bot):
//   Net Profit: +$35,324
//   Win Rate:   64%
//   Profit Factor: 5.85
//   Max DD:    0.71%
// ============================================================
//@version=5
strategy(
    title="BTC Bot v13 (Trend-Only, TP Mode)",
    shorttitle="BTC Bot v13",
    overlay=true,
    pyramiding=0,
    initial_capital=10000,
    default_qty_type=strategy.cash,
    default_qty_value=200,
    commission_type=strategy.commission.percent,
    commission_value=0.05,
    calc_on_order_fills=false,
    calc_on_every_tick=false,
    backtest_fill_limits_assumption=0,
    precision=2
)

// ──────────────────────────────────────────────────────────────
// INPUTS (can be modified in TradingView settings panel)
// ──────────────────────────────────────────────────────────────
emaTrendLen   = input.int(200, "EMA Trend Length")
emaFastLen    = input.int(50,  "EMA Fast Length")
atrLen        = input.int(14,  "ATR Length")
diLen         = input.int(14,  "DI Length")
adxSmooth     = input.int(14,  "ADX Smoothing")
adxEMA        = input.int(5,   "ADX EMA")
rsiLen        = input.int(14,  "RSI Length")

adxTrendTh    = input.int(22,  "ADX Trend Threshold")
adxRangeTh    = input.int(5,   "ADX Range Th. (5=disabled)")

filterATRmult = input.float(1.4, "ATR Filter Mult")
trendRR       = input.float(2.5, "Risk/Reward Ratio")
trendATRmult  = input.float(0.6, "SL ATR Multiplier")
maxSLPoints   = input.float(500.0, "Max SL Points")
beMult        = input.float(0.5, "Breakeven Mult")

// ──────────────────────────────────────────────────────────────
// INDICATORS
// ──────────────────────────────────────────────────────────────
emaTrend = ta.ema(close, emaTrendLen)
emaFast  = ta.ema(close, emaFastLen)
atr      = ta.atr(atrLen)
rsi      = ta.rsi(close, rsiLen)
[dip, dim, adxRaw] = ta.dmi(diLen, adxSmooth)
adx      = ta.ema(adxRaw, adxEMA)
volSMA   = ta.sma(volume, 20)
atrSMA   = ta.sma(atr, 50)

// ──────────────────────────────────────────────────────────────
// REGIME (Range disabled: ADX_RANGE_TH=5)
// ──────────────────────────────────────────────────────────────
trendRegime = adx > adxTrendTh
rangeRegime = adx < adxRangeTh  // NEVER true at 5

// ──────────────────────────────────────────────────────────────
// ENTRY FILTERS
// ──────────────────────────────────────────────────────────────
filtersOK = atr < atrSMA * filterATRmult and volume > volSMA

// ──────────────────────────────────────────────────────────────
// ENTRY CONDITIONS (1:1 match with Python evaluate())
// ──────────────────────────────────────────────────────────────
// Trend Long:  trendRegime AND emaFast > emaTrend AND dip > dim
//              AND close > high[1] AND filtersOK
// Trend Short: trendRegime AND emaFast < emaTrend AND dim > dip
//              AND close < low[1] AND filtersOK
// Range:       DISABLED

trendLong  = trendRegime and emaFast > emaTrend and dip > dim
             and close > high[1] and filtersOK

trendShort = trendRegime and emaFast < emaTrend and dim > dip
             and close < low[1] and filtersOK

// ──────────────────────────────────────────────────────────────
// EXIT LEVELS (1:1 match with Python calc_levels())
// ──────────────────────────────────────────────────────────────
// SL = min(ATR * 0.6, 500)
// TP = entry ± SL * 2.5
// NO TRAILING (TP mode)

stopDist  = math.min(atr * trendATRmult, maxSLPoints)

longSL  = strategy.position_avg_price - stopDist
longTP  = strategy.position_avg_price + stopDist * trendRR
shortSL = strategy.position_avg_price + stopDist
shortTP = strategy.position_avg_price - stopDist * trendRR

// ──────────────────────────────────────────────────────────────
// BREAKEVEN (at ATR * 0.5 profit)
// ──────────────────────────────────────────────────────────────
beThreshold = atr * beMult

beLongActive  = (close - strategy.position_avg_price) >= beThreshold
beShortActive = (strategy.position_avg_price - close) >= beThreshold

// ──────────────────────────────────────────────────────────────
// EXECUTION
// ──────────────────────────────────────────────────────────────

// ENTRY (trend only)
if trendLong and strategy.position_size == 0
    strategy.entry("L", strategy.long)

if trendShort and strategy.position_size == 0
    strategy.entry("S", strategy.short)

// EXIT with breakeven
if strategy.position_size > 0
    activeSL = beLongActive ? strategy.position_avg_price : longSL
    strategy.exit("XL", "L", stop=activeSL, limit=longTP)

if strategy.position_size < 0
    activeSL = beShortActive ? strategy.position_avg_price : shortSL
    strategy.exit("XS", "S", stop=activeSL, limit=shortTP)

// ──────────────────────────────────────────────────────────────
// CHART SIGNALS
// ──────────────────────────────────────────────────────────────
plotshape(trendLong, style=shape.triangleup, location=location.belowbar,
          color=color.new(#00FF00, 0), size=size.small, title="Long Entry")

plotshape(trendShort, style=shape.triangledown, location=location.abovebar,
          color=color.new(#FF0000, 0), size=size.small, title="Short Entry")

// ──────────────────────────────────────────────────────────────
// PERFORMANCE TABLE ON CHART
// ──────────────────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 3,
                         bgcolor=color.new(#000000, 80), border_width=0)
if barstate.islast
    table.cell(t, 0, 0, "BTC Bot v13", text_color=#00FF00, text_size=size.auto)
    table.cell(t, 0, 1, "Regime:", text_color=color.white, text_size=size.auto)
    table.cell(t, 1, 1, trendRegime ? "TREND ▲" : "WAIT",
               text_color=trendRegime ? #00FF00 : #FFA500, text_size=size.auto)
    table.cell(t, 0, 2, "ADX:", text_color=color.white, text_size=size.auto)
    table.cell(t, 1, 2, str.tostring(adx, "#.##"),
               text_color=color.white, text_size=size.auto)
